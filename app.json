{
  "expo": {
    "name": "AI Flashcards",
    "slug": "ai-flashcards",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aiflashcards",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aiflash.app"
    },
    "android": {
      "package": "com.aiflash.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AI Flashcards to access your library to import and scan notes.",
          "cameraPermission": "Allow AI Flashcards to access your camera to scan physical notes."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow AI Flashcards to access your library to manage scanned documents.",
          "savePhotosPermission": "Allow AI Flashcards to save scanned documents to your library."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
